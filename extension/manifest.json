{
  "manifest_version": 3,
  "name": "Voice Browser Agent",
  "version": "1.1",
  "description": "Talk to an AI that controls your browser — powered by LiveKit + Webfuse MCP",
  "background": { "service_worker": "background.js" },
  "side_panel": { "default_path": "sidepanel.html" },
  "host_permissions": ["<all_urls>"],
  "env": [
    { "key": "TOKEN_URL", "value": "", "description": "Token server endpoint (e.g. https://your-server.com/token)" }
  ]
}
