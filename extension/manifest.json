{
  "manifest_version": 3,
  "name": "Voice Browser",
  "version": "1.2",
  "description": "Talk to an AI that controls your browser — powered by LiveKit + Webfuse MCP",
  "background": { "service_worker": "background.js" },
  "side_panel": { "default_path": "sidepanel.html" },
  "host_permissions": ["<all_urls>"],
  "icons": {
    "16": "icon-16.png",
    "32": "icon-32.png",
    "48": "icon-48.png"
  },
  "env": [
    { "key": "TOKEN_URL", "value": "", "description": "Token server endpoint" }
  ]
}
